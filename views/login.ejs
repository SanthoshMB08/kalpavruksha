<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="auth-wrap">
    <div class="auth-card">
      <h1>Welcome Back</h1>
      <div class="subtitle">Login to continue your search</div>

      <% if (error) { %><div class="error-box"><%= error %></div><% } %>

      <form class="auth-form" action="/login" method="POST">
        <div class="field">
          <label class="form-label">Username</label>
          <input type="text" name="username" required autofocus>
        </div>
        <div class="field">
          <label class="form-label">Password</label>
          <input type="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-gold btn-block">Login</button>
      </form>

      <div class="auth-footer-link">New here? <a href="/register" style="color:var(--maroon-800); font-weight:700;">Create a profile</a></div>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
