<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <% const portalLabel = 'Super Admin'; const logoutUrl = '/portal/super-secure-logout'; const showViewToggle = false; %>
  <%- include('../partials/admin-topbar', { portalLabel, logoutUrl, showViewToggle }) %>

  <div class="admin-shell">
    <%- include('../partials/admin-sidebar', { active }) %>

    <main class="admin-main">
      <%- include('../partials/flash') %>

      <div class="stat-cards">
        <div class="stat-card"><div class="value"><%= userCounts.total_users || 0 %></div><div class="label">Total Users</div></div>
        <div class="stat-card"><div class="value"><%= userCounts.pending_users || 0 %></div><div class="label">Pending Users</div></div>
        <div class="stat-card"><div class="value"><%= userCounts.approved_users || 0 %></div><div class="label">Approved Users</div></div>
        <div class="stat-card"><div class="value"><%= userCounts.total_admins || 0 %></div><div class="label">Sub-Admins</div></div>
        <div class="stat-card"><div class="value"><%= totalProfiles %></div><div class="label">Total Profiles</div></div>
      </div>

      <div class="panel quick-links">
        <h3>Quick Links</h3>
        <div class="quick-link-grid">
          <a href="/portal/super-secure-dashboard/admins" class="quick-link-card">🛡️ Sub-Admins (<%= adminCount %>)</a>
          <a href="/portal/super-secure-dashboard/ads" class="quick-link-card">💰 Advertisements (<%= adCount %>)</a>
          <a href="/portal/super-secure-dashboard/stories" class="quick-link-card">💕 Success Stories (<%= storyCount %>)</a>
          <a href="/portal/admin-dashboard" class="quick-link-card">📇 Admin Tools (Users &amp; Profiles)</a>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
