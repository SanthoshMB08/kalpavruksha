<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <a href="javascript:history.back()" style="color:var(--maroon-800); font-weight:700; font-size:0.85rem;">&larr; Back </a>

  <main class="match-feed" style="max-width:1100px; margin:0 auto; padding:36px 24px;">
    <h2 style="margin-bottom:20px;">Saved Profiles</h2>
    <% if (saved.length === 0) { %>
      <div class="empty-state">You haven't saved any profiles yet.</div>
    <% } else { %>
      <div class="profile-grid">
        <% saved.forEach(function(p) { %>
          <div class="profile-card">
            <div class="photo"><img src="/uploads/profiles/<%= p.image_name %>" alt="<%= p.full_name %>"></div>
            <div class="info">
              <h4><%= p.full_name %>, <%= p.age %></h4>
              <div class="meta">
                <div><strong>Caste:</strong> <%= p.caste %></div>
                <div><strong>Occupation:</strong> <%= p.occupation %></div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
