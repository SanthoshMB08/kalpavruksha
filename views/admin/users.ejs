<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <% const portalLabel = 'Admin Portal'; const logoutUrl = '/portal/admin-logout'; const showViewToggle = true; %>
  <%- include('../partials/admin-topbar', { portalLabel, logoutUrl, showViewToggle }) %>

  <div class="admin-shell">
    <%- include('../partials/admin-sidebar', { active }) %>

    <main class="admin-main">
      <%- include('../partials/flash') %>

      <div class="panel">
        <h3>⏳ Pending Approvals</h3>
        <% if (pending.length === 0) { %>
          <div class="empty-state">No pending registrations right now.</div>
        <% } else { %>
          <div class="table-scroll">
          <table class="data-table">
            <thead><tr><th>Name</th><th>Mobile</th><th>Username</th><th>Registered</th><th>Action</th></tr></thead>
            <tbody>
              <% pending.forEach(function(u) { %>
                <tr>
                  <td data-label="Name"><%= u.name %></td>
                  <td data-label="Mobile"><%= u.mobile_number %></td>
                  <td data-label="Username"><%= u.username %></td>
                  <td data-label="Registered"><%= new Date(u.created_at).toLocaleDateString('en-IN') %></td>
                  <td data-label="Action" class="row-actions">
                    <form action="/portal/admin-dashboard/users/<%= u.id %>/approve" method="POST">
                      <button class="btn btn-gold btn-sm" type="submit">Approve Profile</button>
                    </form>
                    <form action="/portal/admin-dashboard/users/<%= u.id %>/reject" method="POST">
                      <button class="btn btn-danger btn-sm" type="submit">Deny Profile</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } %>
      </div>

      <div class="panel">
        <h3>👤 Direct User Creation <span style="font-size:0.75rem; color:#8a7156; font-weight:400;">(bypasses approval, activates instantly)</span></h3>
        <form class="form-grid" action="/portal/admin-dashboard/users/create-direct" method="POST">
          <div class="field">
            <label class="form-label">Full Name</label>
            <input type="text" name="name" required>
          </div>
          <div class="field">
            <label class="form-label">Mobile Number</label>
            <input type="text" name="mobile_number" pattern="[0-9]{10}" maxlength="10" required>
          </div>
          <div class="field">
            <label class="form-label">Username</label>
            <input type="text" name="username" required>
          </div>
          <div class="field">
            <label class="form-label">Password</label>
            <input type="password" name="password" required minlength="8">
          </div>
          <div class="field full">
            <button type="submit" class="btn btn-maroon">Create &amp; Activate User</button>
          </div>
        </form>
      </div>
    </main>
  </div>
</body>
</html>
