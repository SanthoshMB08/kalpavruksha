<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <% const portalLabel = 'Admin Portal'; const logoutUrl = '/portal/admin-logout'; const showViewToggle = true; %>
  <%- include('../partials/admin-topbar', { portalLabel, logoutUrl, showViewToggle }) %>

  <div class="admin-shell">
    <%- include('../partials/admin-sidebar', { active }) %>

    <main class="admin-main">
      <%- include('../partials/flash') %>

      <div class="stat-cards">
        <div class="stat-card"><div class="value"><%= pending.length %></div><div class="label">Pending Approvals</div></div>
        <div class="stat-card"><div class="value"><%= totalProfiles %></div><div class="label">Total Profiles</div></div>
        <div class="stat-card"><div class="value"><%= recentInterests.length %></div><div class="label">Recent Interests</div></div>
      </div>

      <div class="panel">
        <h3>⏳ Pending Approvals <span class="panel-head-link"><a href="/portal/admin-dashboard/users">Manage all &rarr;</a></span></h3>
        <% if (pending.length === 0) { %>
          <div class="empty-state">No pending registrations right now.</div>
        <% } else { %>
          <div class="table-scroll">
          <table class="data-table">
            <thead><tr><th>Name</th><th>Mobile</th><th>Username</th><th>Registered</th><th>Action</th></tr></thead>
            <tbody>
              <% pending.slice(0, 5).forEach(function(u) { %>
                <tr>
                  <td data-label="Name"><%= u.name %></td>
                  <td data-label="Mobile"><%= u.mobile_number %></td>
                  <td data-label="Username"><%= u.username %></td>
                  <td data-label="Registered"><%= new Date(u.created_at).toLocaleDateString('en-IN') %></td>
                  <td data-label="Action" class="row-actions">
                    <form action="/portal/admin-dashboard/users/<%= u.id %>/approve" method="POST">
                      <button class="btn btn-gold btn-sm" type="submit">Approve</button>
                    </form>
                    <form action="/portal/admin-dashboard/users/<%= u.id %>/reject" method="POST">
                      <button class="btn btn-danger btn-sm" type="submit">Deny</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } %>
      </div>

      <div class="panel">
        <h3>🔔 Active Activity Stream</h3>
        <% if (recentInterests.length === 0) { %>
          <div class="empty-state">No interests expressed yet.</div>
        <% } else { %>
          <% recentInterests.forEach(function(i) { %>
            <div class="alert-box">
              <strong><%= i.user_name %></strong> is interested in <strong><%= i.profile_name %></strong>
              (Call: <%= i.profile_phone %>) &mdash; <%= new Date(i.created_at).toLocaleString('en-IN') %>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div class="panel quick-links">
        <h3>Quick Links</h3>
        <div class="quick-link-grid">
          <a href="/portal/admin-dashboard/users" class="quick-link-card">👤 User Approvals &amp; Direct Creation</a>
          <a href="/portal/admin-dashboard/profiles" class="quick-link-card">📇 Manage Profiles</a>
          <a href="/portal/admin-dashboard/profiles/new" class="quick-link-card">➕ Upload New Profile</a>
          <a href="/portal/admin-dashboard/stories" class="quick-link-card">💕 Edit Success Stories</a>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
